# Circle App Kit key from Circle Console.
# This is used by client-side swap calls, so it must be public in a no-backend app.
NEXT_PUBLIC_KIT_KEY=your_circle_console_kit_key

# Optional server-only alias for future backend/server actions.
KIT_KEY=your_circle_console_kit_key

NEXT_PUBLIC_APP_URL=http://localhost:3000
